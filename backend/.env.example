# Copy to .env — see ../CLOUD_SETUP.md for Atlas + S3 steps.

NODE_ENV=development
PORT=4000

# Must match your public URL in production (QR codes use this).
# Local: http://localhost:4000  |  Production: https://your-app.vercel.app
APP_BASE_URL=http://localhost:4000

# --- MongoDB Atlas (cloud) ---
# Get from Atlas → Connect → Drivers → mongodb+srv://...
# Do NOT use mongodb://mongo:27017/... unless you run Docker Compose only.
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/qr_filesharing?retryWrites=true&w=majority
USE_IN_MEMORY_DB=false

# --- Auth (required for login/register) ---
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- AWS S3 (cloud file storage) ---
# Set STORAGE_PROVIDER=s3 (or leave auto and fill all AWS vars below).
STORAGE_PROVIDER=s3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=your-bucket-name

# Limits
MAX_FILE_SIZE_MB=100
FILE_TTL_HOURS=24

# --- Local dev only (no AWS) ---
# Uncomment these and comment out AWS block above if testing without S3:
# STORAGE_PROVIDER=local
# USE_IN_MEMORY_DB=true
# (omit MONGODB_URI to use in-memory Mongo, or set MONGODB_URI + USE_IN_MEMORY_DB=false for Atlas + local disk)
